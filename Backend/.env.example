# ══════════════════════════════════════════════════════════════
#  Server Monitoring Backend – Environment Variables
#  Copy this file to .env and fill in real values
# ══════════════════════════════════════════════════════════════

# Server port
PORT=5000

# Node environment (development / production)
NODE_ENV=production

# MongoDB connection string
# Use a strong password and enable TLS in production:
# Example: mongodb+srv://user:STRONG_PASSWORD@cluster.mongodb.net/dbname?retryWrites=true&w=majority
DATABASEURL=mongodb://localhost:27017/server_monitoring

# JWT Secret – MUST be a long random string (minimum 32 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# CORS Origins – comma-separated list of allowed frontend URLs
# Example: https://monitor.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=https://your-frontend-domain.com

# Email configuration for alerts
EMAIL_USER=alerts@yourdomain.com
EMAIL_PASS=your_email_password
ALERT_EMAIL=admin@yourdomain.com
